<?xml version="1.0"?>
<job_conf>
    <plugins>
        <plugin id="local" type="runner" load="galaxy.jobs.runners.local:LocalJobRunner" workers="4"/>
        <plugin id="pulsar_mq" type="runner" load="galaxy.jobs.runners.pulsar:PulsarMQJobRunner" workers="2">
            <param id="amqp_url">amqp://galaxy:galaxy@192.168.2.2:5672//</param>
            <param id="galaxy_url">http://localhost:8080</param>
        </plugin>
    </plugins>

    <handlers assign_with="db-skip-locked"/>

    <destinations default="tpv_dispatcher">
        <destination id="tpv_dispatcher" runner="dynamic">
            <param id="type">python</param>
            <param id="function">map_tool_to_destination</param>
            <param id="rules_module">tpv.rules</param>
            <param id="tpv_config_files">/home/ubuntu/galaxy/config/tpv_rules_local.yml</param> 
        </destination>
    </destinations>
</job_conf>
